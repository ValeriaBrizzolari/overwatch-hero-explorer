<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hero Details</title>

    <link rel="stylesheet" href="/styles/hero.css" />

    <!-- Fonts -->
    <link
      href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <header>
      <h1><%= hero.name %></h1>
      <p><%= hero.role %></p>
    </header>

    <main class="hero-container">
  <section class="hero-card">
    <div class="hero-top">
      <div class="hero-image-wrapper">
        <img src="<%= hero.portrait %>" alt="<%= hero.name %> portrait" />
      </div>

      <div class="hero-content">
        <section class="overview">
          <h2>Overview</h2>
          <p class="description"><%= hero.description %></p>

          <div class="hero-info">
            <p><strong>Specialty:</strong> <%= hero.location %></p>
          </div>
        </section>
      </div>
    </div>

    <section class="abilities-section">
      <h2>Abilities</h2>

      <div class="abilities-grid">
        <% hero.abilities.forEach((ability) => { %>
          <article class="ability-card">
            <div class="ability-icon-wrapper">
              <img
                class="ability-icon"
                src="<%= ability.icon %>"
                alt="<%= ability.name %> icon"
              />
            </div>

            <h3><%= ability.name %></h3>
            <p><%= ability.description %></p>
          </article>
        <% }) %>
      </div>
    </section>

    <% if (perks) { %>
  <section class="perks-section">
    <h2>Perks</h2>

    <p class="perks-description">
      Unlock mid-match upgrades to outsmart, outplay, and dominate the fight.
    </p>

    <div class="perk-row">
      <div class="perk-card">
        <h4><%= perks.minor.perks[0].name %></h4>
        <p><%= perks.minor.perks[0].description %></p>
      </div>

      <div class="perk-center">
        <p class="perk-label">Minor Perk</p>
        <p class="perk-level">Level <%= perks.minor.level %></p>

        <div class="perk-icons">
          <div class="perk-icon-circle">
            <img src="<%= perks.minor.perks[0].icon %>" alt="<%= perks.minor.perks[0].name %> icon" />
          </div>

          <div class="perk-icon-circle">
            <img src="<%= perks.minor.perks[1].icon %>" alt="<%= perks.minor.perks[1].name %> icon" />
          </div>
        </div>
      </div>

      <div class="perk-card">
        <h4><%= perks.minor.perks[1].name %></h4>
        <p><%= perks.minor.perks[1].description %></p>
      </div>
    </div>

    <div class="perk-row">
      <div class="perk-card">
        <h4><%= perks.major.perks[0].name %></h4>
        <p><%= perks.major.perks[0].description %></p>
      </div>

      <div class="perk-center">
        <p class="perk-label">Major Perk</p>
        <p class="perk-level">Level <%= perks.major.level %></p>

        <div class="perk-icons">
          <div class="perk-icon-circle">
            <img src="<%= perks.major.perks[0].icon %>" alt="<%= perks.major.perks[0].name %> icon" />
          </div>

          <div class="perk-icon-circle">
            <img src="<%= perks.major.perks[1].icon %>" alt="<%= perks.major.perks[1].name %> icon" />
          </div>
        </div>
      </div>

      <div class="perk-card">
        <h4><%= perks.major.perks[1].name %></h4>
        <p><%= perks.major.perks[1].description %></p>
      </div>
    </div>
  </section>
<% } %>


 <section class="story-section">
  <h2>Story</h2>

  <div class="story-summary">
    <p><%= hero.story.summary %></p>
  </div>

  <% if (hero.story.media && hero.story.media.link) { %>
    <div class="story-video">
      <iframe
        src="https://www.youtube.com/embed/<%= hero.story.media.link.split('youtu.be/')[1] %>"
        title="Hero Story Video"
        frameborder="0"
        allowfullscreen
      ></iframe>
    </div>
  <% } %>
</section>

<section class="chapters-section">
  <h2>Chapters</h2>

  <div class="chapters-grid">
    <% hero.story.chapters.forEach((chapter) => { %>
      <article class="chapter-card">
        <img src="<%= chapter.picture %>" alt="<%= chapter.title %>" />

        <h3><%= chapter.title %></h3>

        <p><%= chapter.content %></p>
      </article>
    <% }) %>
  </div>
</section>



    <a href="/" class="back-btn">← Back to Heroes</a>
  </section>
</main>
  </body>
</html>
